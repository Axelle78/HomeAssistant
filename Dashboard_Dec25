                    primary: >-
                      {% set prog = states('sensor.seche_linge_program_name')
                      %}  {% set labels = {
                        'hqd_delicate': 'Délicat',
                        'hqd_cotton': 'Coton',
                        'hqd_mix': 'Mixte',
                        'hqd_synthetic': 'Synthétique',
                        'hqd_smart_ai': 'Smart AI',
                        'hqd_eco': 'Eco'
                      } %}  {{ labels[prog] if prog in labels else prog }}
                    secondary: >-
                      {% set remain =
                      states('sensor.seche_linge_remaining_time') | int(0) %} 
                      {% set start =
                      as_timestamp(states('sensor.seche_linge_start_time'), 0)
                      %}  {% set elapsed = (as_timestamp(now()) - start) / 60
                      %}  {% set total = elapsed + remain %}  {% set pct =
                      ((elapsed / total) * 100) | round(0) if total > 0 else 0
                      %}  Progression : {{ pct }}% | Reste {{ remain }} min
                    card_mod:
                      style: |
                        ha-card {
                          {% set mode = states('sensor.seche_linge_mode') | lower %}
                          {% set remain = states('sensor.seche_linge_remaining_time') | int(0) %}
                          /* Affiche si le mode est running ou si le temps > 0 */
                          display: {{ 'flex' if 'run' in mode or remain > 0 else 'none' }};
                          
                          {% if 'run' in mode or remain > 0 %}
                            {% set start = as_timestamp(states('sensor.seche_linge_start_time'), 0) %}
                            {% set elapsed = (as_timestamp(now()) - start) / 60 %}
                            {% set total = elapsed + remain %}
                            {% set pct = ((elapsed / total) * 100) | round(0) if total > 0 else 0 %}
                            background: linear-gradient(90deg, rgba(255, 152, 0, 0.2) {{ pct }}%, rgba(0,0,0,0) {{ pct }}%) !important;
                          {% endif %}
                          margin: 10px;
                        }
                  - type: custom:mushroom-chips-card
                    alignment: center
                    chips:
                      - type: template
                        icon: mdi:clock-check
                        content: >-
                          {% set remain =
                          states('sensor.seche_linge_remaining_time') | int(0)
                          %} Fin estimée : {{ (now() +
                          timedelta(minutes=remain)).strftime('%H:%M') }}
                    card_mod:
                      style: |
                        ha-card {
                          {% set mode = states('sensor.seche_linge_mode') | lower %}
                          {% set remain = states('sensor.seche_linge_remaining_time') | int(0) %}
                          /* On force l'affichage si le cycle tourne */
                          display: {{ 'flex' if 'run' in mode or remain > 0 else 'none' }};
                          margin-bottom: 10px;
                        }

void drawLightBulbIcon(int x, int y, uint32_t color, bool isOn) {
  // Ampoule
  M5.Display.fillCircle(x, y, 12, color);
  M5.Display.fillRect(x - 6, y + 8, 12, 8, color);
  M5.Display.drawRect(x - 8, y + 16, 16, 4, color);
  
  // Lignes de lumière si allumée
  if (isOn) {
    M5.Display.drawLine(x - 18, y - 8, x - 22, y - 12, TFT_YELLOW);
    M5.Display.drawLine(x + 18, y - 8, x + 22, y - 12, TFT_YELLOW);
    M5.Display.drawLine(x - 20, y, x - 24, y, TFT_YELLOW);
    M5.Display.drawLine(x + 20, y, x + 24, y, TFT_YELLOW);
    M5.Display.drawLine(x - 14, y + 10, x - 18, y + 14, TFT_YELLOW);
    M5.Display.drawLine(x + 14, y + 10, x + 18, y + 14, TFT_YELLOW);
  }
}

void drawThermometerIcon(int x, int y, uint32_t color) {
  // Tube
  M5.Display.fillRect(x - 3, y - 15, 6, 20, color);
  // Bulbe
  M5.Display.fillCircle(x, y + 8, 6, color);
  // Lignes de mesure
  M5.Display.drawLine(x + 4, y - 12, x + 8, y - 12, WHITE);
  M5.Display.drawLine(x + 4, y - 6, x + 8, y - 6, WHITE);
  M5.Display.drawLine(x + 4, y, x + 8, y, WHITE);
}

void drawGearIcon(int x, int y, uint32_t color) {
  // Engrenage simplifié
  M5.Display.fillCircle(x, y, 10, color);
  M5.Display.fillCircle(x, y, 6, BLACK);
  // Dents
  M5.Display.fillRect(x - 2, y - 14, 4, 6, color);
  M5.Display.fillRect(x - 2, y + 8, 4, 6, color);
  M5.Display.fillRect(x - 14, y - 2, 6, 4, color);
  M5.Display.fillRect(x + 8, y - 2, 6, 4, color);
}

void drawRadiatorIcon(int x, int y, uint32_t color, bool isHeating) {
  // Corps du radiateur
  for (int i = 0; i < 4; i++) {
    M5.Display.fillRoundRect(x - 12 + (i * 8), y - 10, 6, 20, 2, color);
  }
  
  // Lignes de chaleur si en chauffe
  if (isHeating) {
    M5.Display.drawLine(x - 8, y - 16, x - 6, y - 20, TFT_ORANGE);
    M5.Display.drawLine(x, y - 16, x + 2, y - 20, TFT_ORANGE);
    M5.Display.drawLine(x + 8, y - 16, x + 10, y - 20, TFT_ORANGE);
  }
}

void drawStatusBar() {
  M5.Display.fillRect(0, 0, 320, 30, TFT_NAVY);
  
  // WiFi
  if (WiFi.status() == WL_CONNECTED) {
    M5.Display.fillRect(10, 18, 4, 8, TFT_GREEN);
    M5.Display.fillRect(16, 14, 4, 12, TFT_GREEN);
    M5.Display.fillRect(22, 10, 4, 16, TFT_GREEN);
  } else {
    M5.Display.drawLine(10, 10, 26, 26, TFT_RED);
    M5.Display.drawLine(26, 10, 10, 26, TFT_RED);
  }
  
  // Batterie
  int batX = 260;
  int batY = 8;
  M5.Display.drawRect(batX, batY, 35, 16, WHITE);
  M5.Display.fillRect(batX + 35, batY + 5, 3, 6, WHITE);
  
  // Couleur selon le niveau - DIRECTEMENT sans variable
  int fillWidth = (batteryLevel * 31) / 100;
  M5.Display.fillRect(batX + 2, batY + 2, fillWidth, 12, 
    batteryLevel < 20 ? TFT_RED : (batteryLevel < 50 ? TFT_ORANGE : TFT_GREEN));
  
  M5.Display.setTextSize(1);
  M5.Display.setTextColor(WHITE);
  M5.Display.setCursor(batX - 30, batY + 4);
  M5.Display.printf("%d%%", batteryLevel);
  
  // Indicateurs de page (petits points) - CENTRÉ - 10 pages (0-9)
  int dotY = 20;
  int startX = 110;
  for (int i = 0; i < 10; i++) {
    M5.Display.fillCircle(startX + i * 10, dotY, 3, (i == currentPage) ? TFT_ORANGE : TFT_DARKGREY);
  }
}


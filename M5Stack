void handleTouch() {
  if (M5.Touch.getCount()) {
    auto t = M5.Touch.getDetail();
    
    // Si l'écran est éteint, on gère UNIQUEMENT le rallumage
    if (!screenOn) {
      // Ne rallumer que si assez de temps s'est écoulé depuis l'extinction manuelle
      if (millis() - lastManualSleep > WAKE_DELAY) {
        screenOn = true;
        M5.Display.setBrightness(screenBrightness);
        lastActivity = millis();
        lastWakeUp = millis();  // Enregistrer le moment du rallumage
        drawCurrentPage();
      }
      // IMPORTANT : Toujours return ici, même si on n'a pas rallumé
      // pour éviter de traiter le touch comme une action sur une page
      return;
    }
    
    // Mettre à jour l'activité seulement si l'écran est allumé
    lastActivity = millis();
    
    // Ignorer tous les événements tactiles pendant 1 seconde après le rallumage
    // pour éviter d'activer des boutons par accident (sauf au premier démarrage)
    if (lastWakeUp > 0 && millis() - lastWakeUp < SLEEP_DELAY) {
      return;
    }
    
    // Détection du début du swipe
    if (t.wasPressed()) {
      touchStartX = t.x;
      touchStartY = t.y;
      isSwiping = false;
    }
    
    // Détection du swipe en cours
    if (t.isPressed()) {
      int deltaX = t.x - touchStartX;
      int deltaY = abs(t.y - touchStartY);
      
      if (abs(deltaX) > 30 && deltaY < 50) {
        isSwiping = true;
      }
    }
    
    // Fin du swipe
    if (t.wasReleased() && isSwiping) {
      int deltaX = t.x - touchStartX;
      
      if (abs(deltaX) > SWIPE_THRESHOLD) {
        if (deltaX > 0) {
          // Swipe droite = page précédente
          currentPage--;
          if (currentPage < 0) currentPage = 9;
        } else {
          // Swipe gauche = page suivante
          currentPage++;
          if (currentPage > 9) currentPage = 0;
        }
        
        Serial.printf("Swipe! Page: %d\n", currentPage);
        drawCurrentPage();
        isSwiping = false;
        return;
      }
    }
    
    // Si pas de swipe, gérer les touches normales
    if (!isSwiping && t.wasReleased()) {
      if (millis() - lastTouch < 300) return;
      lastTouch = millis();
      
      // Boutons physiques
      if (t.y >= BTN_Y_MIN && t.y <= BTN_Y_MAX) {
        if (t.x <= BTN_LEFT_MAX) {
          currentPage--;
          if (currentPage < 0) currentPage = 9;
          drawCurrentPage();
          return;
        }
        else if (t.x >= BTN_MIDDLE_MIN && t.x <= BTN_MIDDLE_MAX) {
          screenOn = false;
          lastManualSleep = millis();  // Enregistrer le moment de l'extinction
          M5.Display.setBrightness(0);
          M5.Display.fillScreen(BLACK);
          return;
        }
        else if (t.x >= BTN_RIGHT_MIN) {
          currentPage++;
          if (currentPage > 9) currentPage = 0;
          drawCurrentPage();
          return;
        }
      }
      
      // PAGE 0 : Lumières
      if (currentPage == 0 && t.y >= 65 && t.y <= 190) {
        if (t.x <= 160) {
          light1_state = !light1_state;
          String payload = light1_state ? "{\"state\":\"ON\"}" : "{\"state\":\"OFF\"}";
          mqtt.publish("homeassistant/light/light1/set", payload.c_str());
          drawCurrentPage();
        } else {
          light2_state = !light2_state;
          String payload = light2_state ? "{\"state\":\"ON\"}" : "{\"state\":\"OFF\"}";
          mqtt.publish("homeassistant/light/light2/set", payload.c_str());
          drawCurrentPage();
        }
      }
      
      // PAGE 1 : Routines Alexa (design toggle vertical)
      if (currentPage == 1) {
        // Ligne 1 : La table (toute la ligne est cliquable)
        if (t.y >= 70 && t.y <= 105) {
          routine_table_state = !routine_table_state;
          String payload = routine_table_state ? "{\"state\":\"on\"}" : "{\"state\":\"off\"}";
          mqtt.publish("homeassistant/input_boolean/alexa_routine_la_table/set", payload.c_str());
          drawCurrentPage();
        }
        // Ligne 2 : Lave vaisselle
        else if (t.y >= 115 && t.y <= 160) {
          routine_vaisselle_state = !routine_vaisselle_state;
          String payload = routine_vaisselle_state ? "{\"state\":\"on\"}" : "{\"state\":\"off\"}";
          mqtt.publish("homeassistant/input_boolean/alexa_routine_la_vaisselle/set", payload.c_str());
          drawCurrentPage();
        }
        // Ligne 3 : A table
        else if (t.y >= 170 && t.y <= 215) {
          routine_a_table_state = !routine_a_table_state;
          String payload = routine_a_table_state ? "{\"state\":\"on\"}" : "{\"state\":\"off\"}";
          mqtt.publish("homeassistant/input_boolean/alexa_routine_a_table/set", payload.c_str());
          drawCurrentPage();
        }
      }
      
      // PAGE 3 : Paramètres (était page 2)
      if (currentPage == 3) {
        if (t.x >= 40 && t.x <= 140 && t.y >= 185 && t.y <= 230) {
          screenBrightness -= 25;
          if (screenBrightness < 25) screenBrightness = 25;
          M5.Display.setBrightness(screenBrightness);
          drawCurrentPage();
        }
        else if (t.x >= 180 && t.x <= 280 && t.y >= 185 && t.y <= 230) {
          screenBrightness += 25;
          if (screenBrightness > 255) screenBrightness = 255;
          M5.Display.setBrightness(screenBrightness);
          drawCurrentPage();
        }
        else if (t.x >= 30 && t.x <= 290 && t.y >= 120 && t.y <= 140) {
          screenBrightness = ((t.x - 30) * 255) / 260;
          if (screenBrightness < 25) screenBrightness = 25;
          if (screenBrightness > 255) screenBrightness = 255;
          M5.Display.setBrightness(screenBrightness);
          drawCurrentPage();
        }
      }
      
      // PAGES 4-6 : Radiateurs (étaient pages 3-5)
      if (currentPage >= 4 && currentPage <= 6) {
        if (t.x >= 40 && t.x <= 140 && t.y >= 185 && t.y <= 230) {
          float* target = (currentPage == 4) ? &rad1_target : (currentPage == 5) ? &rad2_target : &rad3_target;
          *target -= 0.5;
          if (*target < 7.0) *target = 7.0;
          
          StaticJsonDocument<200> doc;
          doc["temperature"] = *target;
          char buffer[200];
          serializeJson(doc, buffer);
          
          char topic[50];
          sprintf(topic, "homeassistant/climate/rad%d/set", currentPage - 3);
          mqtt.publish(topic, buffer);
          
          drawCurrentPage();
        }
        else if (t.x >= 180 && t.x <= 280 && t.y >= 185 && t.y <= 230) {
          float* target = (currentPage == 4) ? &rad1_target : (currentPage == 5) ? &rad2_target : &rad3_target;
          *target += 0.5;
          if (*target > 30.0) *target = 30.0;
          
          StaticJsonDocument<200> doc;
          doc["temperature"] = *target;
          char buffer[200];
          serializeJson(doc, buffer);
          
          char topic[50];
          sprintf(topic, "homeassistant/climate/rad%d/set", currentPage - 3);
          mqtt.publish(topic, buffer);
          
          drawCurrentPage();
        }
      }
    }
  }
}

// ===== PUBLICATION DES CAPTEURS =====

void publishSensors() {
  if (!mqtt.connected()) return;
  
  StaticJsonDocument<256> doc;
  char buffer[256];
  
  // 1. Batterie (niveau en %) - met à jour la variable globale pour l'affichage
  batteryLevel = M5.Power.getBatteryLevel();
  doc["battery"] = batteryLevel;
  serializeJson(doc, buffer);
  mqtt.publish("homeassistant/sensor/m5stack/battery", buffer);
  
  // 2. WiFi RSSI (force du signal)
  doc.clear();
  doc["rssi"] = WiFi.RSSI();
  serializeJson(doc, buffer);
  mqtt.publish("homeassistant/sensor/m5stack/rssi", buffer);
  
  // 3. Uptime (en minutes)
  doc.clear();
  unsigned long uptimeMinutes = millis() / 60000;
  doc["uptime"] = uptimeMinutes;
  serializeJson(doc, buffer);
  mqtt.publish("homeassistant/sensor/m5stack/uptime", buffer);
  
  // 4. Mémoire libre (en KB)
  doc.clear();
  doc["free_heap"] = ESP.getFreeHeap() / 1024;
  serializeJson(doc, buffer);
  mqtt.publish("homeassistant/sensor/m5stack/free_heap", buffer);
  
  // 5. IMU - Accéléromètre (si présent)
  auto imu_update = M5.Imu.update();
  if (imu_update) {
    auto data = M5.Imu.getImuData();
    
    // Accélération
    doc.clear();
    doc["accel_x"] = round(data.accel.x * 100) / 100.0;
    doc["accel_y"] = round(data.accel.y * 100) / 100.0;
    doc["accel_z"] = round(data.accel.z * 100) / 100.0;
    serializeJson(doc, buffer);
    mqtt.publish("homeassistant/sensor/m5stack/accelerometer", buffer);
    
    // Gyroscope
    doc.clear();
    doc["gyro_x"] = round(data.gyro.x * 100) / 100.0;
    doc["gyro_y"] = round(data.gyro.y * 100) / 100.0;
    doc["gyro_z"] = round(data.gyro.z * 100) / 100.0;
    serializeJson(doc, buffer);
    mqtt.publish("homeassistant/sensor/m5stack/gyroscope", buffer);
  }
  
  Serial.println("Capteurs publiés sur MQTT");
}

void loop() {
  M5.update();
  
  // Extinction manuelle par bouton power
  if (M5.BtnPWR.wasPressed()) {
    Serial.println("Extinction manuelle...");
    mqtt.publish("m5stack/state", "offline");
    delay(100);
    M5.Display.setBrightness(0);
    M5.Display.fillScreen(BLACK);
    M5.Power.setLed(0);
    M5.Power.powerOff();
  }
  
  // Extinction de l'écran après 1 minute
  if (screenOn && (millis() - lastActivity > SCREEN_TIMEOUT)) {
    Serial.println("Extinction ecran (timeout)");
    screenOn = false;
    lastManualSleep = millis();  // Enregistrer pour éviter rallumage immédiat
    M5.Display.setBrightness(0);
    M5.Display.fillScreen(BLACK);
  }
  
  // Extinction complète après 5 minutes d'inactivité
  if (millis() - lastActivity > SHUTDOWN_TIMEOUT) {
    Serial.println("Extinction automatique apres 5 minutes...");
    mqtt.publish("m5stack/state", "offline_auto");
    delay(100);
    M5.Display.setBrightness(0);
    M5.Display.fillScreen(BLACK);
    M5.Power.setLed(0);
    M5.Power.powerOff();
  }
  
  // Gestion LED
  if (screenOn) {
    M5.Power.setLed(128);
  } else {
    M5.Power.setLed(0);
  }
  
  // Connexion MQTT
  if (!mqtt.connected()) {
    reconnectMQTT();
  }
  mqtt.loop();
  
  // Mise à jour de la batterie pour l'affichage (toutes les 5 secondes)
  unsigned long now = millis();
  if (now - lastMsg > 5000) {
    lastMsg = now;
    batteryLevel = M5.Power.getBatteryLevel();
    batteryVoltage = M5.Power.getBatteryVoltage() / 1000.0;
    
    // Rafraîchir la barre de statut si l'écran est allumé
    if (screenOn) {
      drawStatusBar();
    }
  }
  
  // Envoi de tous les capteurs toutes les 30 secondes
  if (now - lastSensorPublish > 30000) {
    lastSensorPublish = now;
    publishSensors();
  }
  
  handleTouch();
  
  delay(50);
}

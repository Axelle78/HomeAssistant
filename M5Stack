  } else if (state == "off") {
    displayState = "OFF";
  }
  
  // Couleur directe selon l'état
  M5.Display.setTextColor(state == "heating" ? TFT_ORANGE : (state == "idle" ? TFT_BLUE : TFT_DARKGREY));
  M5.Display.print(displayState);
  M5.Display.setTextColor(WHITE);
  
  // Consigne
  M5.Display.setTextSize(2);
  M5.Display.setCursor(50, 155);
  M5.Display.print("Consigne: ");
  M5.Display.setTextSize(3);
  M5.Display.printf("%.1f", target);
  M5.Display.setTextSize(2);
  M5.Display.print("C");
  
  // Boutons +/-
  M5.Display.fillRoundRect(40, 185, 100, 45, 10, TFT_BLUE);
  M5.Display.setTextSize(4);
  M5.Display.setTextColor(WHITE);
  M5.Display.setCursor(75, 193);
  M5.Display.print("-");
  
  M5.Display.fillRoundRect(180, 185, 100, 45, 10, TFT_RED);
  M5.Display.setCursor(215, 193);
  M5.Display.print("+");
  
  drawNavigationBar();
}


void drawEnergyPage(String title, String value, String unit, String evolution, bool inverseLogic = false) {
  M5.Display.fillScreen(BLACK);
  
  // TEST: On ne dessine PAS la barre de statut pour voir si c'est elle qui cause le problème
  drawStatusBar();  // REMIS
  
  // Debug dans le Serial Monitor
  Serial.print("Page ");
  Serial.print(title);
  Serial.print(" - Valeur: ");
  Serial.print(value);
  Serial.print(" - Evolution: ");
  Serial.println(evolution);
  
  // Gérer les valeurs manquantes
  if (value == "--" || evolution == "--") {
    // Si pas de données, afficher en gris
    M5.Display.fillRect(15, 50, 290, 140, TFT_DARKGREY);
    
    M5.Display.setTextSize(2);
    M5.Display.setTextColor(WHITE);
    M5.Display.setCursor(160 - (title.length() * 6), 70);
    M5.Display.print(title);
    
    M5.Display.setTextSize(2);
    M5.Display.setCursor(90, 110);
    M5.Display.print("En attente...");
    
    drawNavigationBar();
    return;
  }
  
  // Déterminer la couleur selon l'évolution
  float evolValue = evolution.toFloat();
  
  Serial.print("Evolution (float): ");
  Serial.println(evolValue);
  
  // Pour la couleur : inverseLogic = true pour coûts/conso (hausse=mauvais), false pour production (hausse=bon)
  bool isGood = inverseLogic ? (evolValue < 0) : (evolValue > 0);
  
  Serial.print("isGood: ");
  Serial.println(isGood ? "OUI" : "NON");
  
  Serial.print("Couleur logique: ");
  Serial.println(isGood ? "VERT" : "ROUGE");
  
  // Pour la flèche : toujours basée sur le signe de l'évolution
  String arrow = (evolValue >= 0) ? "^" : "v";
  
  // SOLUTION: Utiliser les couleurs DIRECTEMENT sans variable intermédiaire
  // Dessiner EXACTEMENT comme la page de test - avec fillRect
  // Bordure colorée (cadre extérieur) - couleur DIRECTE
  M5.Display.fillRect(15, 50, 290, 140, isGood ? TFT_GREEN : TFT_RED);
  // Fond gris par dessus (laisse 3px de bordure)
  M5.Display.fillRect(18, 53, 284, 134, TFT_DARKGREY);
  
  // Titre
  M5.Display.setTextSize(2);
  M5.Display.setTextColor(WHITE);
  M5.Display.setCursor(160 - (title.length() * 6), 70);
  M5.Display.print(title);
  
  // Valeur principale
  M5.Display.setTextSize(3);
  String displayValue = value + " " + unit;
  M5.Display.setCursor(160 - (displayValue.length() * 9), 100);
  M5.Display.print(displayValue);
  
  // Ligne de séparation
  M5.Display.fillRect(80, 130, 160, 1, TFT_LIGHTGREY);
  
  // Évolution avec flèche - couleur DIRECTE aussi
  M5.Display.setTextSize(2);
  M5.Display.setTextColor(isGood ? TFT_GREEN : TFT_RED);  // Couleur DIRECTE
  String evolText = arrow + " " + evolution + "%";
  M5.Display.setCursor(160 - (evolText.length() * 6), 145);
  M5.Display.print(evolText);
  
  drawNavigationBar();  // REMIS
}


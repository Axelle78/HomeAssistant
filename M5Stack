void setup() {
  M5.Display.setSwapBytes(true);
  Serial.begin(115200);
  delay(1000);
  Serial.println("\n=== Demarrage M5Stack Core2 ===");
  
  auto cfg = M5.config();
  M5.begin(cfg);
  
  M5.Display.setBrightness(screenBrightness);
  M5.Display.setRotation(1);
  
  setupWiFi();
  
  mqtt.setServer(mqtt_server, mqtt_port);
  mqtt.setCallback(mqttCallback);
  
  lastActivity = millis();
  
  drawCurrentPage();
  Serial.println("=== Setup termine ===");
}

void setupWiFi() {
  Serial.print("Connexion WiFi...");
  M5.Display.fillScreen(BLACK);
  M5.Display.setTextSize(2);
  M5.Display.setCursor(80, 100);
  M5.Display.println("Connexion WiFi...");
  
  WiFi.begin(ssid, password);
  
  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED && attempts < 20) {
    delay(500);
    Serial.print(".");
    attempts++;
  }
  
  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\nWiFi OK!");
    Serial.println(WiFi.localIP());
  } else {
    Serial.println("\nWiFi ECHEC!");
  }
}

void mqttCallback(char* topic, byte* payload, unsigned int length) {
  String message;
  for (int i = 0; i < length; i++) {
    message += (char)payload[i];
  }
  
  String topicStr = String(topic);
  
  StaticJsonDocument<512> doc;
  DeserializationError error = deserializeJson(doc, message);
  
  if (!error) {
    // Lumières
    if (topicStr == "homeassistant/light/light1/state") {
      light1_state = (doc["state"].as<String>() == "ON");
      if (currentPage == 0 && screenOn) drawCurrentPage();
    }
    else if (topicStr == "homeassistant/light/light2/state") {
      light2_state = (doc["state"].as<String>() == "ON");
      if (currentPage == 0 && screenOn) drawCurrentPage();
    }
    // Routines Alexa (page 1)
    else if (topicStr == "homeassistant/input_boolean/alexa_routine_la_table/state") {
      routine_table_state = (doc["state"].as<String>() == "on");
      if (currentPage == 1 && screenOn) drawCurrentPage();
    }
    else if (topicStr == "homeassistant/input_boolean/alexa_routine_la_vaisselle/state") {
      routine_vaisselle_state = (doc["state"].as<String>() == "on");
      if (currentPage == 1 && screenOn) drawCurrentPage();
    }
    else if (topicStr == "homeassistant/input_boolean/alexa_routine_a_table/state") {
      routine_a_table_state = (doc["state"].as<String>() == "on");
      if (currentPage == 1 && screenOn) drawCurrentPage();
    }
    // Températures (page 2, était page 1)
    else if (topicStr == "homeassistant/sensor/temp1") {
      temp1 = doc["state"].as<String>();
      if (currentPage == 2 && screenOn) drawCurrentPage();
    }
    else if (topicStr == "homeassistant/sensor/temp2") {
      temp2 = doc["state"].as<String>();
      if (currentPage == 2 && screenOn) drawCurrentPage();
    }
    else if (topicStr == "homeassistant/sensor/temp3") {
      temp3 = doc["state"].as<String>();
      if (currentPage == 2 && screenOn) drawCurrentPage();
    }
    else if (topicStr == "homeassistant/sensor/temp4") {
      temp4 = doc["state"].as<String>();
      if (currentPage == 2 && screenOn) drawCurrentPage();
    }
    // Radiateurs (pages 4-6, étaient pages 3-5)
    else if (topicStr == "homeassistant/climate/rad1/state") {
      if (doc.containsKey("current_temperature")) {
        rad1_temp = String(doc["current_temperature"].as<float>(), 1);
      }
      if (doc.containsKey("temperature")) {
        rad1_target = doc["temperature"].as<float>();
      }
      if (doc.containsKey("hvac_action")) {
        rad1_state = doc["hvac_action"].as<String>();
      }
      if (currentPage == 4 && screenOn) drawCurrentPage();
    }
    else if (topicStr == "homeassistant/climate/rad2/state") {
      if (doc.containsKey("current_temperature")) {
        rad2_temp = String(doc["current_temperature"].as<float>(), 1);
      }
      if (doc.containsKey("temperature")) {
        rad2_target = doc["temperature"].as<float>();
      }
      if (doc.containsKey("hvac_action")) {
        rad2_state = doc["hvac_action"].as<String>();
      }
      if (currentPage == 5 && screenOn) drawCurrentPage();
    }
    else if (topicStr == "homeassistant/climate/rad3/state") {
      if (doc.containsKey("current_temperature")) {
        rad3_temp = String(doc["current_temperature"].as<float>(), 1);
      }
      if (doc.containsKey("temperature")) {
        rad3_target = doc["temperature"].as<float>();
      }
      if (doc.containsKey("hvac_action")) {
        rad3_state = doc["hvac_action"].as<String>();
      }
      if (currentPage == 6 && screenOn) drawCurrentPage();
    }
    // Données énergétiques (pages 7-9, étaient pages 6-8)
    else if (topicStr == "homeassistant/sensor/cout_total") {
      cout_total = doc["state"].as<String>();
      if (currentPage == 7 && screenOn) drawCurrentPage();
    }
    else if (topicStr == "homeassistant/sensor/evol_hier_cout") {
      evol_cout = doc["state"].as<String>();
      if (currentPage == 7 && screenOn) drawCurrentPage();
    }
    else if (topicStr == "homeassistant/sensor/conso_total") {
      conso_total = doc["state"].as<String>();
      if (currentPage == 8 && screenOn) drawCurrentPage();
    }
    else if (topicStr == "homeassistant/sensor/evol_hier_conso") {
      evol_conso = doc["state"].as<String>();
      if (currentPage == 8 && screenOn) drawCurrentPage();
    }
    else if (topicStr == "homeassistant/sensor/production_kwh") {
      production_total = doc["state"].as<String>();
      if (currentPage == 9 && screenOn) drawCurrentPage();
    }
    else if (topicStr == "homeassistant/sensor/evol_hier_production") {
      evol_production = doc["state"].as<String>();
      if (currentPage == 9 && screenOn) drawCurrentPage();
    }
  }
}

void reconnectMQTT() {
  if (!mqtt.connected()) {
    Serial.print("Connexion MQTT...");
    if (mqtt.connect(mqtt_client_id, mqtt_user, mqtt_password)) {
      Serial.println("OK!");
      
      mqtt.subscribe("homeassistant/light/light1/state");
      mqtt.subscribe("homeassistant/light/light2/state");
      mqtt.subscribe("homeassistant/input_boolean/alexa_routine_la_table/state");
      mqtt.subscribe("homeassistant/input_boolean/alexa_routine_la_vaisselle/state");
      mqtt.subscribe("homeassistant/input_boolean/alexa_routine_a_table/state");
      mqtt.subscribe("homeassistant/sensor/temp1");
      mqtt.subscribe("homeassistant/sensor/temp2");
      mqtt.subscribe("homeassistant/sensor/temp3");
      mqtt.subscribe("homeassistant/sensor/temp4");
      mqtt.subscribe("homeassistant/climate/rad1/state");
      mqtt.subscribe("homeassistant/climate/rad2/state");
      mqtt.subscribe("homeassistant/climate/rad3/state");
      mqtt.subscribe("homeassistant/sensor/cout_total");
      mqtt.subscribe("homeassistant/sensor/evol_hier_cout");
      mqtt.subscribe("homeassistant/sensor/conso_total");
      mqtt.subscribe("homeassistant/sensor/evol_hier_conso");
      mqtt.subscribe("homeassistant/sensor/production_kwh");
      mqtt.subscribe("homeassistant/sensor/evol_hier_production");
      
      mqtt.publish("m5stack/state", "online");
    } else {
      Serial.print("Echec, rc=");
      Serial.println(mqtt.state());
    }
  }
}

